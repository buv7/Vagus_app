# VAGUS App - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ==================== Supabase Configuration ====================
# Flutter Client Configuration (Required)
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://kydrpnrmqbedjflklgue.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Database Direct Connection (Optional - for backend/MCP tools only)
# Connection string for PostgreSQL session pooler
# Get from: Supabase Dashboard → Settings → Database → Connection string → Session mode
# Format: postgresql://postgres.{ref}:{password}@{pooler-host}:5432/postgres
# This is NOT used by the Flutter app - only for server-side tools
DATABASE_URL=postgresql://postgres.kydrpnrmqbedjflklgue:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ==================== WebRTC / TURN Configuration ====================
# ExpressTURN free tier: 1000 GB/mo relay — https://www.expressturn.com
# Get credentials from ExpressTURN dashboard after signup
EXPRESSTURN_USER=your-expressturn-username
EXPRESSTURN_PASS=your-expressturn-password

# ==================== OneSignal Configuration ====================
# Get these from: OneSignal Dashboard → Settings → Keys & IDs
ONESIGNAL_APP_ID=your-onesignal-app-id

# ==================== Environment ====================
# Options: development, staging, production
ENVIRONMENT=development

# ==================== Optional Configuration ====================
# Uncomment and configure if needed

# API Base URL (if using custom backend)
# API_BASE_URL=https://api.example.com

# Debug Mode (true/false)
# DEBUG_MODE=true

# Sentry DSN (for error tracking)
# SENTRY_DSN=your-sentry-dsn

# ==================== Honesty-Pass Feature Flags ====================
# These flags gate features whose backing services are still stubs,
# mocks, or otherwise not production-ready. ALL DEFAULT TO FALSE.
#
# These values are read at BUILD time via --dart-define, NOT at
# runtime from .env. The entries below document the available flags;
# to actually enable one, pass it to flutter run / flutter build:
#
#   flutter run \
#     --dart-define=CALLING_ENABLED=true \
#     --dart-define=OCR_ENABLED=true \
#     --dart-define=HEALTH_SYNC_ENABLED=true \
#     --dart-define=GOOGLE_APPS_ENABLED=true \
#     --dart-define=STRIPE_ENABLED=true
#
# CALLING_ENABLED=false        # Voice / video calling (Agora / WebRTC)
# OCR_ENABLED=false            # OCR / barcode nutrition scanning
# HEALTH_SYNC_ENABLED=false    # Apple Health / Google Fit / Health Connect
# GOOGLE_APPS_ENABLED=false    # Google Sheets / Drive / Calendar
# STRIPE_ENABLED=false         # Stripe / payment-gateway upgrades

# ==================== Notes ====================
# 1. After copying to .env, run: flutter pub get
# 2. Verify with: flutter run
# 3. You should see: "✅ Environment variables loaded"
# 4. If variables are missing, app will use defaults (may not work correctly)
