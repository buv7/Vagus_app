# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Environment variables - NEVER COMMIT
.env
.env.backup
.env.problematic
.env.local
.env.*.local
*.env
supabase_connection.env
node_modules/

# Analyzer scratch output
.analyzer.*.txt

# Archived code - exclude from analysis
ARCHIVE/
# Re-include the lowercase archive/ tree (legacy-sql kept on purpose for forensic
# reference). The ARCHIVE/ rule above catches archive/ too on case-insensitive
# filesystems (Windows/macOS); this negation puts archive/ back under git.
!archive/
!archive/**
.vercel

# OXBAR staging secrets - NEVER COMMIT
.oxbar/staging-secrets.md
